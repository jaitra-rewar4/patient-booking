DATABASE_URL="file:./dev.db"
ADMIN_PASSWORD=demo-admin-2026
ADMIN_SESSION_SECRET=replace-with-random-32-char-string

# Production / Vercel only. When TURSO_DATABASE_URL is set, the runtime
# Prisma client routes through Turso (libSQL) instead of the local SQLite
# file. Leave both unset for local development.
# TURSO_DATABASE_URL=libsql://...turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...
